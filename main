<head>
    <title>Ultimate 118-Element Atom Sim</title>
    <style>
        body { background: #050508; color: #fff; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; overflow: hidden; display: flex; }
        .sidebar { width: 320px; background: rgba(20, 20, 25, 0.95); height: 100vh; padding: 30px; border-right: 1px solid #333; z-index: 10; box-shadow: 10px 0 30px rgba(0,0,0,0.5); }
        .canvas-container { flex-grow: 1; display: flex; justify-content: center; align-items: center; background: radial-gradient(circle, #1a1a2e 0%, #050508 100%); }
        h1 { font-size: 28px; margin: 0; color: #00d4ff; text-shadow: 0 0 10px rgba(0,212,255,0.5); }
        .symbol { font-size: 64px; font-weight: bold; margin: 10px 0; color: #fff; }
        input[type=range] { width: 100%; margin: 20px 0; accent-color: #00d4ff; }
        .data-row { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 14px; border-bottom: 1px solid #222; padding-bottom: 4px; }
        .label { color: #888; text-transform: uppercase; letter-spacing: 1px; font-size: 10px; }
        .value { color: #00ffcc; font-family: monospace; font-weight: bold; }
        .shell-viz { margin-top: 20px; display: flex; gap: 4px; }
        .shell-bit { background: #333; padding: 5px; border-radius: 4px; font-size: 12px; flex: 1; text-align: center; }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="label">Atomic Number</div>
    <h1 id="atNum">1</h1>
    <div id="elSymbol" class="symbol">H</div>
    <h2 id="elName" style="margin-top:0; color:#aaa;">Hydrogen</h2>
    
    <input type="range" id="slider" min="1" max="118" value="1" oninput="update()">

    <div class="data-row"><span class="label">Protons</span><span class="value" id="pCount">1</span></div>
    <div class="data-row"><span class="label">Neutrons</span><span class="value" id="nCount">0</span></div>
    <div class="data-row"><span class="label">Electrons</span><span class="value" id="eCount">1</span></div>
    
    <div class="label" style="margin-top:20px;">Electron Configuration</div>
    <div id="shellBox" class="shell-viz"></div>
</div>

<div class="canvas-container">
    <canvas id="canvas"></canvas>
</div>

<script>
const elementNames = [
    "Hydrogen", "Helium", "Lithium", "Beryllium", "Boron", "Carbon", "Nitrogen", "Oxygen", "Fluorine", "Neon",
    "Sodium", "Magnesium", "Aluminum", "Silicon", "Phosphorus", "Sulfur", "Chlorine", "Argon", "Potassium", "Calcium",
    "Scandium", "Titanium", "Vanadium", "Chromium", "Manganese", "Iron", "Cobalt", "Nickel", "Copper", "Zinc",
    "Gallium", "Germanium", "Arsenic", "Selenium", "Bromine", "Krypton", "Rubidium", "Strontium", "Yttrium", "Zirconium",
    "Niobium", "Molybdenum", "Technetium", "Ruthenium", "Rhodium", "Palladium", "Silver", "Cadmium", "Indium", "Tin",
    "Antimony", "Tellurium", "Iodine", "Xenon", "Cesium", "Barium", "Lanthanum", "Cerium", "Praseodymium", "Neodymium",
    "Promethium", "Samarium", "Europium", "Gadolinium", "Terbium", "Dysprosium", "Holmium", "Erbium", "Thulium", "Ytterbium",
    "Lutetium", "Hafnium", "Tantalum", "Tungsten", "Rhenium", "Osmium", "Iridium", "Platinum", "Gold", "Mercury",
    "Thallium", "Lead", "Bismuth", "Polonium", "Astatine", "Radon", "Francium", "Radium", "Actinium", "Thorium",
    "Protactinium", "Uranium", "Neptunium", "Plutonium", "Americium", "Curium", "Berkelium", "Californium", "Einsteinium", "Fermium",
    "Mendelevium", "Nobelium", "Lawrencium", "Rutherfordium", "Dubnium", "Seaborgium", "Bohrium", "Hassium", "Meitnerium", "Darmstadtium",
    "Roentgenium", "Copernicium", "Nihonium", "Flerovium", "Moscovium", "Livermorium", "Tennessine", "Oganesson"
];

const elementSymbols = [
    "H", "He", "Li", "Be", "B", "C", "N", "O", "F", "Ne", "Na", "Mg", "Al", "Si", "P", "S", "Cl", "Ar", "K", "Ca",
    "Sc", "Ti", "V", "Cr", "Mn", "Fe", "Co", "Ni", "Cu", "Zn", "Ga", "Ge", "As", "Se", "Br", "Kr", "Rb", "Sr", "Y", "Zr",
    "Nb", "Mo", "Tc", "Ru", "Rh", "Pd", "Ag", "Cd", "In", "Sn", "Sb", "Te", "I", "Xe", "Cs", "Ba", "La", "Ce", "Pr", "Nd",
    "Pm", "Sm", "Eu", "Gd", "Tb", "Dy", "Ho", "Er", "Tm", "Yb", "Lu", "Hf", "Ta", "W", "Re", "Os", "Ir", "Pt", "Au", "Hg",
    "Tl", "Pb", "Bi", "Po", "At", "Rn", "Fr", "Ra", "Ac", "Th", "Pa", "U", "Np", "Pu", "Am", "Cm", "Bk", "Cf", "Es", "Fm",
    "Md", "No", "Lr", "Rf", "Db", "Sg", "Bh", "Hs", "Mt", "Ds", "Rg", "Cn", "Nh", "Fl", "Mc", "Lv", "Ts", "Og"
];

const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
let currentZ = 1;
let angle = 0;

function getShells(Z) {
    let shells = [0,0,0,0,0,0,0];
    let remaining = Z;
    // Capacity logic for visualization (Simplified Bohr)
    const limits = [2, 8, 18, 32, 32, 18, 8];
    for(let i=0; i<limits.length; i++) {
        let add = Math.min(remaining, limits[i]);
        shells[i] = add;
        remaining -= add;
        if(remaining <= 0) break;
    }
    return shells.filter(s => s > 0);
}

function update() {
    currentZ = parseInt(document.getElementById('slider').value);
    document.getElementById('atNum').innerText = currentZ;
    document.getElementById('elSymbol').innerText = elementSymbols[currentZ-1];
    document.getElementById('elName').innerText = elementNames[currentZ-1];
    document.getElementById('pCount').innerText = currentZ;
    document.getElementById('eCount').innerText = currentZ;
    
    // Neutron calculation (Stability curve approximation)
    let n = Math.round(currentZ * (1 + (currentZ/350))); 
    if(currentZ > 20) n = Math.round(currentZ * 1.3);
    if(currentZ > 80) n = Math.round(currentZ * 1.5);
    if(currentZ === 1) n = 0;
    document.getElementById('nCount').innerText = n;

    // Update Shell UI
    const shells = getShells(currentZ);
    const sBox = document.getElementById('shellBox');
    sBox.innerHTML = '';
    shells.forEach(s => {
        let div = document.createElement('div');
        div.className = 'shell-bit';
        div.innerText = s;
        sBox.appendChild(div);
    });
}

function resize() {
    canvas.width = window.innerWidth - 320;
    canvas.height = window.innerHeight;
}

window.addEventListener('resize', resize);
resize();

function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    const cx = canvas.width / 2;
    const cy = canvas.height / 2;
    const shells = getShells(currentZ);
    
    // Draw Nucleus
    const nSize = 10 + (currentZ * 0.15);
    const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, nSize * 2);
    grad.addColorStop(0, '#ff3333');
    grad.addColorStop(0.5, '#4444ff');
    grad.addColorStop(1, 'transparent');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.arc(cx, cy, nSize * 3, 0, Math.PI*2);
    ctx.fill();

    // Draw Orbits & Electrons
    shells.forEach((count, idx) => {
        const radius = 60 + (idx * 40);
        ctx.beginPath();
        ctx.arc(cx, cy, radius, 0, Math.PI*2);
        ctx.strokeStyle = 'rgba(255,255,255,0.1)';
        ctx.stroke();

        for(let i=0; i<count; i++) {
            const eAngle = (angle * (1 / (idx + 1))) + (i * (Math.PI * 2 / count));
            const ex = cx + Math.cos(eAngle) * radius;
            const ey = cy + Math.sin(eAngle) * radius;

            ctx.beginPath();
            ctx.arc(ex, ey, 4, 0, Math.PI*2);
            ctx.fillStyle = '#00ffcc';
            ctx.shadowBlur = 10;
            ctx.shadowColor = '#00ffcc';
            ctx.fill();
            ctx.shadowBlur = 0;
        }
    });

    angle += 0.015;
    requestAnimationFrame(animate);
}

update();
animate();
</script>
</body>
</html>
